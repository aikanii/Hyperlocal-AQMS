# --- HY-AQMS Production Configuration ---

# Domain used for SSL (Let's Encrypt)
DOMAIN=dashboard.yourdomain.com
EMAIL=admin@yourdomain.com

# Node.js Backend
NODE_ENV=production
PORT=3000
JWT_SECRET=CHANGE_ME_TO_A_LONG_SECURE_RANDOM_STRING

# TimeScaleDB (PostgreSQL)
# DO NOT USE 'secret' IN PRODUCTION
POSTGRES_DB=aqms
POSTGRES_USER=aqms_user
POSTGRES_PASSWORD=CHANGE_ME_SECURELY
POSTGRES_HOST=timescale

# MQTT Broker (Mosquitto)
# DO NOT USE 'mypassword' IN PRODUCTION
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=mydevice
MQTT_PASSWORD=CHANGE_ME_FOR_MQTT

# Redis Cache
# Used for hot-storage of latest readings
REDIS_URL=redis://redis:6379

# Reference Node Scraper
# Full URL of the webpage that contains the PM2.5 AQI reading for the Reference Node.
# The page is scraped via HTML parsing (cheerio); it must include an element whose
# CSS class attribute contains the substring "_aqidata_" with a numeric text value.
# The scraper polls this URL every 5 minutes and stores the result as the reference reading.
REFERENCE_URL=https://your-reference-aq-page.example.com
